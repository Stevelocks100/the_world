{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "cases": [
      {
        "when": "stevelocks",
        "model": {
          "type": "minecraft:select",
          "property": "minecraft:display_context",
          "cases": [
            {
              "when": "firstperson_righthand",
              "model": {
                "type": "minecraft:model",
                "model": "theworld:item/right_hand_steve"
              }
            },
            {
              "when": "firstperson_lefthand",
              "model": {
                "type": "minecraft:model",
                "model": "theworld:item/left_hand_steve"
              }
            },
            {
              "when": "gui",
              "model": {
                "type": "minecraft:model",
                "model": "minecraft:item/armor_stand"
              }
            }
          ],
          "fallback": {
            "type": "minecraft:empty"
          }
        }
      }
    ],
    "fallback": {
      "type": "minecraft:select",
      "property": "minecraft:display_context",
      "cases": [
        {
          "when": "firstperson_righthand",
          "model": {
            "type": "minecraft:model",
            "model": "theworld:item/right_hand"
          }
        },
        {
          "when": "firstperson_lefthand",
          "model": {
            "type": "minecraft:model",
            "model": "theworld:item/left_hand"
          }
        },
        {
          "when": "gui",
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/armor_stand"
          }
        }
      ],
      "fallback": {
        "type": "minecraft:empty"
      }
    }
  },
  "swap_animation_scale": 2
}